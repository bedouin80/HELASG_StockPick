 ({ \"PickListLine\": varitem, \"PickListBatch\": (varitem['batches']) });\n      ListPLLinesBatches.push(ListBatchData);\n    } else {\n      var itembatch_list = (varitem['batches']);\n      for (var itembatch_index in itembatch_list) {\n        itembatch = itembatch_list[itembatch_index];\n        ListBatchData = ({ \"PickListLine\": varitem, \"PickListBatch\": itembatch });\n        ListPLLinesBatches.push(ListBatchData);\n      }\n    }\n  }\n}\n\n\nPickListLines = (msg['DBResult']['PickList']['Lines']);\nListPLLinesBatches = [];\nif (Array.isArray(PickListLines) == false) {\n  do_something(PickListLines);\n} else {\n  for (var item_index in PickListLines) {\n    item = PickListLines[item_index];\n    do_something(item);\n  }\n}\nmsg['DBResult']['PickListBatch'] = ListPLLinesBatches;\nnode.send([msg]);\n","workspaceXml":"<xml xmlns=\"https://developers.google.com/blockly/xml\">\n  <variables>\n    <variable id=\"MN3jK?=(IOW8tM8PFP[s\">PickListLines</variable>\n    <variable id=\"M+unJ]6_:g$~0]zK]j@m\">varitem</variable>\n    <variable id=\"$zf#wRp9gW-U+G#^t`X;\">ListPLLinesBatches</variable>\n    <variable id=\"~`oYt:K=26)FC/{f!)-t\">ListBatchData</variable>\n    <variable id=\"A-,$O)LJq:9F9`-d{KHW\">item</variable>\n    <variable id=\"zZ;.6KVd)=[G1V8fZKR|\">itembatch</variable>\n  </variables>\n  <block type=\"variables_set\" id=\"2KnsM$B3c[sAE+DZm|T`\" x=\"-862\" y=\"-687\">\n    <field name=\"VAR\" id=\"MN3jK?=(IOW8tM8PFP[s\">PickListLines</field>\n    <value name=\"VALUE\">\n      <block type=\"node_object_get\" id=\"*gc*0]Ny~05p]v.su!sR\">\n        <mutation xmlns=\"http://www.w3.org/1999/xhtml\" action=\"GET\"></mutation>\n        <field name=\"action\">GET</field>\n        <value name=\"object\">\n          <shadow type=\"node_msg\" id=\"EjHO|zPAcL#RI~+UFMS^\"></shadow>\n        </value>\n        <value name=\"field_name\">\n          <shadow type=\"text\" id=\"8c3]tfdUVP5v#SA3k%T!\">\n            <field name=\"TEXT\">DBResult.PickList.Lines</field>\n   