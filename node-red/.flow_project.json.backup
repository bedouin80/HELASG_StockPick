tem_index in SalesOrderRows) {\n    item = SalesOrderRows[item_index];\n    do_something(item);\n  }\n}\nmsg['DBResult']['SAPSalesOrderBatches'] = ListSalesOrderRowBatches;\nnode.send([msg]);\n","workspaceXml":"<xml xmlns=\"https://developers.google.com/blockly/xml\">\n  <variables>\n    <variable id=\"MN3jK?=(IOW8tM8PFP[s\">SalesOrderRows</variable>\n    <variable id=\"3x15IQBWNGpM[~T#GJF]\">varitem</variable>\n    <variable id=\"$zf#wRp9gW-U+G#^t`X;\">ListSalesOrderRowBatches</variable>\n    <variable id=\"~`oYt:K=26)FC/{f!)-t\">RowBatchData</variable>\n    <variable id=\"A-,$O)LJq:9F9`-d{KHW\">item</variable>\n    <variable id=\"zZ;.6KVd)=[G1V8fZKR|\">itembatch</variable>\n  </variables>\n  <block type=\"variables_set\" id=\"2KnsM$B3c[sAE+DZm|T`\" x=\"-1062\" y=\"-712\">\n    <field name=\"VAR\" id=\"MN3jK?=(IOW8tM8PFP[s\">SalesOrderRows</field>\n    <value name=\"VALUE\">\n      <block type=\"node_object_get\" id=\"*gc*0]Ny~05p]v.su!sR\">\n        <mutation xmlns=\"http://www.w3.org/1999/xhtml\" action=\"GET\"></mutation>\n        <field name=\"action\">GET</field>\n        <value name=\"object\">\n          <shadow type=\"node_msg\" id=\"EjHO|zPAcL#RI~+UFMS^\"></shadow>\n        </value>\n        <value name=\"field_name\">\n          <shadow type=\"text\" id=\"8c3]tfdUVP5v#SA3k%T!\">\n            <field name=\"TEXT\">DBResult.SAPSalesOrder.Rows</field>\n          </shadow>\n        </value>\n      </block>\n    </value>\n    <next>\n      <block type=\"variables_set\" id=\"z^mV3}#U33R{R_~?ql_^\">\n        <field name=\"VAR\" id=\"$zf#wRp9gW-U+G#^t`X;\">ListSalesOrderRowBatches</field>\n        <value name=\"VALUE\">\n          <block type=\"lists_create_with\" id=\"@sSdp@3i{`bw@e#aFN]U\">\n            <mutation items=\"0\"></mutation>\n          </block>\n        </value>\n        <next>\n          <block type=\"controls_if\" id=\"5t}wK;%}-J/(~mar==WE\">\n            <mutation else=\"1\"></mutation>\n            <value name=\"IF0\">\n              <block type=