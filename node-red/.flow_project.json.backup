eliveryZoneList, PostalCode, ZoneFound, ZoneText, item, DZonePostalCode, itemCode;\n\n\nDeliveryZoneList = (msg['SearchPostalCode']['data']);\nPostalCode = (msg['SearchPostalCode']['text']);\nZoneFound = false;\nZoneText = '';\nfor (var item_index in DeliveryZoneList) {\n  item = DeliveryZoneList[item_index];\n  DZonePostalCode = (item['PostalCodes']).split(',');\n  for (var itemCode_index in DZonePostalCode) {\n    itemCode = DZonePostalCode[itemCode_index];\n    if (itemCode.length == 6 && itemCode == PostalCode) {\n      ZoneFound = true;\n      break;\n    } else if (itemCode.length == 2 && PostalCode.startsWith(itemCode) == true) {\n      ZoneFound = true;\n      break;\n    }\n  }\n  if (ZoneFound == true) {\n    ZoneText = (item['Name']);\n    break;\n  }\n}\nmsg['payload'] = ZoneText;\nnode.send([msg]);\n","workspaceXml":"<xml xmlns=\"https://developers.google.com/blockly/xml\">\n  <variables>\n    <variable id=\"^`Kq1*LWUkPK3at4(pXv\">DeliveryZoneList</variable>\n    <variable id=\"r!Ub,LWuRG|g5_Sd]oAr\">PostalCode</variable>\n    <variable id=\"~5Ftq$Ea*AK:^oOhAh0f\">ZoneFound</variable>\n    <variable id=\"KbZ}$T%F]#*kU:!tt?Y`\">ZoneText</variable>\n    <variable id=\"A-,$O)LJq:9F9`-d{KHW\">item</variable>\n    <variable id=\"c#~GSX-60J][{bbcD+gv\">DZonePostalCode</variable>\n    <variable id=\"Nv9E-X-fN#r3UoPQJQPI\">itemCode</variable>\n  </variables>\n  <block type=\"variables_set\" id=\"2Fa80Md8y;K8g/Bm[:5c\" x=\"-838\" y=\"-712\">\n    <field name=\"VAR\" id=\"^`Kq1*LWUkPK3at4(pXv\">DeliveryZoneList</field>\n    <value name=\"VALUE\">\n      <block type=\"node_object_get\" id=\"j=;Uq*V4qa8En]2t5n*g\">\n        <mutation xmlns=\"http://www.w3.org/1999/xhtml\" action=\"GET\"></mutation>\n        <field name=\"action\">GET</field>\n        <value name=\"object\">\n          <shadow type=\"node_msg\" id=\"O(u!lMJQyu66!zG[orny\"></shadow>\n        </value>\n        <value name=\"field_name\">\n          <shadow type=\"text\" id=\"a0vYmR#jN.UF)!YP{ZO(\">\n 