,"tot":"msg","dc":true}],"action":"","property":"","from":"","to":"","reg":false,"x":760,"y":520,"wires":[["281f6cb384138607"]]},{"id":"ec8b52a1296b1cd4","type":"function","z":"cc7039c22215981b","name":"Tracking Script","func":"\nvar currentService = \"\";\n\nif (msg.currentService===undefined) {\n    if (msg[env.get('Service')+'Service']===undefined) {\n        msg[env.get('Service')+'Service'] = {};\n    }\n\n    currentService = env.get('Service')+'Service'+\":\"\n\n    if (msg[env.get('Service')+'Service'][env.get('Function')] === undefined) {\n        msg[env.get('Service')+'Service'][env.get('Function')] = msg.payload;    \n        currentService += env.get('Function')\n    } else {\n        var found = false;\n        var i=1;\n        var funcvar = \"\";\n        while (!found) {\n            funcvar = env.get('Function')+\"(\"+i+\")\";\n            if (msg[env.get('Service')+'Service'][funcvar]===undefined) {\n                msg[env.get('Service')+'Service'][funcvar] = msg.payload;\n                found=true;\n            }\n            i++;\n        }\n        currentService += funcvar\n    }\n\n    msg.currentService = currentService\n\n    //check for DBService and Backup\n    if (msg.DBService!==undefined) {\n        msg.DBServiceStore = msg.DBService\n        delete msg.DBService\n    }\n    \n} else {\n\n    currentService = msg.currentService;\n\n    msg[currentService.split(\":\")[0]][currentService.split(\":\")[1]].payload = msg.payload\n\n    msg.currentService = undefined;\n\n    //check for DBServiceStore and restore\n    if (msg.DBServiceStore!==undefined) {\n        msg.DBService = msg.DBServiceStore \n        delete msg.DBServiceStore\n    }\n\n}\n\n\nreturn msg;","outputs":1,"timeout":0,"noerr":0,"initialize":"","finalize":"","libs":[],"x":260,"y":140,"wires":[[]]},{"id":"4d941f24a69298bb","type":"Blockly","z":"bc809a43177e3cf6","func":"if ((msg['req']['method']) == 'POST' && (msg['req']['url']) == '/batch/current') {\n  node.send([null, null, null, null, msg, null, null, null, null]);\n} else if ((msg['req']['method']) == 'POST' && (msg['req']['url']) == '/batch/currentm') {\n  node.send([null, msg, null, null, null, null, null, null, null]);\n} else if ((msg['req']['method']) == 'POST' && (msg['req']['url']) == '/batch/submit') {\n  node.send([null, null, null, null, null, msg, null, null, null]);\n} else if ((msg['req']['method']) == 'POST' && (msg['req']['url']) == '/batch/check') {\n  node.send([null, null, null, null, null, null, msg, null, null]);\n} else if ((msg['req']['method']) == 'GET' && (msg['req']['url']) == '/batch/batchwarn') {\n  node.send([null, null, msg, null, null, null, null, null, null]);\n} else if ((msg['req']['method']) == 'GET' && (msg['req']['url']) == '/batch/batchwarnprev') {\n  node.send([null, null, null, msg, null, null, null, null, null]);\n} else {\n  node.send([msg, null, null, null, null, null, null, null, null]);\n}\n","workspaceXml":"<xml xmlns=\"https://developers.google.com/blockly/xml\">\n  <block type=\"controls_if\" id=\"$Tc1XD6t31FYl#=5{l1B\" x=\"-963\" y=\"-262\">\n    <mutation elseif=\"5\" else=\"1\"></mutation>\n    <value name=\"IF0\">\n      <block type=\"logic_operation\" id=\"g[@lwFPZ!Abeh3)x8v$V\">\n        <field name=\"OP\">AND</field>\n        <value name=\"A\">\n          <block type=\"logic_compare\" id=\"|E8[*RzN7^)5fY-CQW#.\">\n            <field name=\"OP\">EQ</field>\n            <value name=\"A\">\n              <block type=\"node_object_get\" id=\"Y,2i+HoP5/|3##p^(IJO\">\n                <mutation xmlns=\"http://www.w3.org/1999/xhtml\" action=\"GET\"></mutation>\n                <field name=\"action\">GET</field>\n                <value name=\"object\">\n                  <shadow type=\"node_msg\" id=\"1B1}1!utc*oF+5YR7,Jl\"></shadow>\n                </value>\n                <value name=\"field_name\">\n                  <shadow type=\"text\" id=\"kE@x7I8Dzfge.;*2~1X@\">\n                    <field name=\"TEXT\">req.method</field>\n 